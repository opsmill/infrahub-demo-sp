{% import '_macros.j2' as m %}
{% set device = data.DcimDevice.edges[0].node %}
{% set isis = data.MplsIsisProcess.edges[0].node %}
{% set ldp = data.MplsLdpProcess.edges[0].node %}
{% set bgp = data.MplsBgpProcess.edges[0].node %}
{% set sites = data.ServiceL3VpnSite.edges
    | selectattr('node.pe_interface.node')
    | selectattr('node.pe_address.node')
    | selectattr('node.l3vpn.node.vrf.node')
    | list %}
/* Juniper Junos configuration for {{ device.name.value }} */
system {
    host-name {{ device.name.value }};
    no-redirects;
}
interfaces {
    /* Loopback */
    lo0 {
        unit 0 {
{% for iface in device.interfaces.edges if iface.node.name.value == 'Loopback0' %}
{% for ip in iface.node.ip_addresses.edges %}
            family inet {
                address {{ ip.node.address.value }};
            }
{% endfor %}
{% endfor %}
            family iso {
                address {{ isis.net_id.value }};
            }
            family mpls;
        }
    }
    /* Backbone interfaces */
{% for iface in device.interfaces.edges if iface.node.role.value == 'core' %}
    {{ iface.node.name.value }} {
        description "{{ iface.node.description.value }}";
        mtu {{ iface.node.mtu.value }};
        unit 0 {
{% for ip in iface.node.ip_addresses.edges %}
            family inet {
                address {{ ip.node.address.value }};
            }
{% endfor %}
            family mpls;
        }
    }
{% endfor %}
    /* Customer-facing interfaces (VRF-bound) */
{% for site_edge in sites %}
{% set site = site_edge.node %}
    {{ site.pe_interface.node.name.value }} {
        description "L3VPN {{ site.l3vpn.node.name.value }} - {{ site.name.value }}";
        unit 0 {
            family inet {
                address {{ site.pe_address.node.address.value }};
            }
        }
    }
{% endfor %}
}
protocols {
    isis {
{% for iface in device.interfaces.edges if iface.node.role.value == 'core' %}
        interface {{ iface.node.name.value }}.0 {
            point-to-point;
            level 2 metric 10;
        }
{% endfor %}
        interface lo0.0 {
            passive;
        }
    }
    ldp {
{% for iface in device.interfaces.edges if iface.node.role.value == 'core' %}
        interface {{ iface.node.name.value }}.0;
{% endfor %}
        interface lo0.0;
    }
    bgp {
        group ibgp-mesh {
            type internal;
            local-address {{ ldp.router_id.value }};
            family inet-vpn {
                unicast;
            }
            family inet6-vpn {
                unicast;
            }
{% for session in bgp.sessions.edges if session.node.session_type.value == 'INTERNAL' %}
            neighbor {{ m.ip_only(session.node.remote_ip.node.address.value) }};
{% endfor %}
        }
    }
    mpls {
{% for iface in device.interfaces.edges if iface.node.role.value == 'core' %}
        interface {{ iface.node.name.value }}.0;
{% endfor %}
    }
}
{% set seen_vpns = [] %}
{% for site_edge in sites %}
{% set vpn = site_edge.node.l3vpn.node %}
{% if vpn.name.value not in seen_vpns %}
{% set _ = seen_vpns.append(vpn.name.value) %}
{% set vpn_name = vpn.name.value %}
routing-instances {
    {{ vpn_name }} {
        instance-type vrf;
        route-distinguisher {{ vpn.vrf.node.vrf_rd.value }};
        vrf-import import-{{ vpn_name }};
        vrf-export export-{{ vpn_name }};
{% for s in sites if s.node.l3vpn.node.name.value == vpn_name %}
        interface {{ s.node.pe_interface.node.name.value }}.0;
{% endfor %}
        protocols {
            bgp {
                group ce {
                    type external;
{% for s in sites if s.node.l3vpn.node.name.value == vpn_name %}
{% if s.node.routing_protocol.value == 'ebgp' %}
                    peer-as {{ s.node.bgp_peer_asn.value }};
                    neighbor {{ m.ip_only(s.node.ce_address.node.address.value) }};
{% endif %}
{% endfor %}
                }
            }
        }
    }
}
policy-options {
    policy-statement import-{{ vpn_name }} {
        from community comm-{{ vpn_name }};
        then accept;
    }
    policy-statement export-{{ vpn_name }} {
        then {
            community add comm-{{ vpn_name }};
            accept;
        }
    }
    community comm-{{ vpn_name }} members target:{{ vpn.vrf.node.import_rt.node.name.value }};
}
{% endif %}
{% endfor %}
